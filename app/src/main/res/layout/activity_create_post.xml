<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_background"
    android:padding="20dp">

    <TextView
        android:id="@+id/tv_back_create_post"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingVertical="8dp"
        android:text="&lt; Back"
        android:textColor="@color/neon_blue"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_create_post_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:text="Share Post"
        android:textColor="@color/text_white"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_back_create_post" />

    <EditText
        android:id="@+id/et_post_content"
        android:layout_width="0dp"
        android:layout_height="160dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/card_background_dark"
        android:gravity="top"
        android:hint="Share your run today..."
        android:inputType="textMultiLine|textCapSentences"
        android:padding="16dp"
        android:textColor="@color/text_white"
        android:textColorHint="@color/text_grey"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_create_post_title" />

    <ImageView
        android:id="@+id/iv_selected_post_image"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/card_background_dark"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_post_content" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_pick_post_image"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="16dp"
        android:text="Choose Image"
        android:textAllCaps="false"
        android:textColor="@color/text_white"
        app:backgroundTint="@color/card_surface"
        app:cornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_selected_post_image" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_share_post"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:text="Share Post"
        android:textAllCaps="false"
        android:textColor="@color/text_white"
        android:textStyle="bold"
        app:backgroundTint="@color/neon_blue"
        app:cornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_pick_post_image" />

</androidx.constraintlayout.widget.ConstraintLayout>
