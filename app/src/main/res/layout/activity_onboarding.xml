<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_background"
    android:orientation="vertical"
    android:padding="24dp">

    <ProgressBar
        android:id="@+id/onboarding_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:max="9"
        android:progress="1"
        android:progressTint="@color/neon_blue" />

    <ViewFlipper
        android:id="@+id/view_flipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:inAnimation="@android:anim/slide_in_left"
        android:outAnimation="@android:anim/slide_out_right">

        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Usual Distance?" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
            <RadioGroup android:id="@+id/rg_distance" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="30dp">
                <RadioButton android:layout_width="match_parent" android:layout_height="60dp" android:text="Short (Under 5km)" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="60dp" android:text="Medium (5km - 15km)" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="60dp" android:text="Long (Over 15km)" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
            </RadioGroup>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Running Style?" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
            <RadioGroup android:id="@+id/rg_type" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="30dp">
                <RadioButton android:layout_width="match_parent" android:layout_height="60dp" android:text="Casual / Recovery" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="60dp" android:text="Training / Tempo" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="60dp" android:text="Competitive / Race" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
            </RadioGroup>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Runs Per Week?" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
            <RadioGroup android:id="@+id/rg_freq" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="30dp">
                <RadioButton android:layout_width="match_parent" android:layout_height="60dp" android:text="1-2 times" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="60dp" android:text="3-4 times" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="60dp" android:text="5+ times" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
            </RadioGroup>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Running Experience?" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
            <RadioGroup android:id="@+id/rg_experience" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="30dp">
                <RadioButton android:layout_width="match_parent" android:layout_height="58dp" android:text="Less than 3 months" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="58dp" android:text="3 months - 1 year" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="58dp" android:text="1 - 3 years" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="58dp" android:text="3+ years" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
            </RadioGroup>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Average Pace?" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
            <RadioGroup android:id="@+id/rg_pace" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="30dp">
                <RadioButton android:layout_width="match_parent" android:layout_height="60dp" android:text="More than 8:00 min/km" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="60dp" android:text="6:00 - 8:00 min/km" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="60dp" android:text="Below 6:00 min/km" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
            </RadioGroup>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Weekly Distance?" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
            <RadioGroup android:id="@+id/rg_weekly_distance" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="30dp">
                <RadioButton android:layout_width="match_parent" android:layout_height="58dp" android:text="Below 10 km/week" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="58dp" android:text="10 - 25 km/week" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="58dp" android:text="25 - 50 km/week" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="58dp" android:text="50+ km/week" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
            </RadioGroup>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Main Goal?" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
            <RadioGroup android:id="@+id/rg_goal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="30dp">
                <RadioButton android:layout_width="match_parent" android:layout_height="52dp" android:text="Weight loss / health" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="52dp" android:text="Fitness / 5K preparation" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="52dp" android:text="10K / half marathon" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="52dp" android:text="Marathon / competitive racing" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
            </RadioGroup>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Recovery Habit?" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
            <RadioGroup android:id="@+id/rg_recovery" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="30dp">
                <RadioButton android:layout_width="match_parent" android:layout_height="60dp" android:text="Poor recovery / rarely stretch" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="60dp" android:text="Average recovery" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="60dp" android:text="Good rest and stretching" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
            </RadioGroup>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Race Experience?" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
            <RadioGroup android:id="@+id/rg_events" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp">
                <RadioButton android:layout_width="match_parent" android:layout_height="50dp" android:text="Never joined events" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="50dp" android:text="Fun runs only" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="50dp" android:text="10K / half marathon" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:id="@+id/rb_event_marathon" android:layout_width="match_parent" android:layout_height="50dp" android:text="Marathon / competitive races" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
            </RadioGroup>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="Injury History" android:textColor="@color/text_white" android:textSize="18sp" android:textStyle="bold" />
            <RadioGroup android:id="@+id/rg_injury" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp">
                <RadioButton android:layout_width="match_parent" android:layout_height="44dp" android:text="No injuries" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="44dp" android:text="Occasional pain" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="44dp" android:text="Frequent / recovering" android:textColor="@color/text_white" android:buttonTint="@color/neon_blue"/>
            </RadioGroup>
        </LinearLayout>
    </ViewFlipper>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_back"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:text="BACK"
            android:textColor="@color/text_grey"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="2"
            android:background="@drawable/gradient_button_bg"
            android:text="NEXT"
            android:textColor="@color/text_white"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
